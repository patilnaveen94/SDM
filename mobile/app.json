{
  "expo": {
    "name": "SDM Camera & Solutions",
    "slug": "sdm-solutions",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sdmcamerasolutions.app"
    },
    "android": {
      "backgroundColor": "#0A0A0A",
      "package": "com.sdmcamerasolutions.app"
    },
    "plugins": [
      "expo-av"
    ]
  }
}
